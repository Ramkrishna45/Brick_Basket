generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ============================================
// User
// ============================================

model User {
  id           String   @id @default(cuid())
  name         String
  email        String   @unique
  emailVerified DateTime?
  image        String?
  phone        String?
  passwordHash String?
  role         String   @default("customer") // customer | engineer | admin | contractor
  avatar       String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  // Relations
  customerProjects Project[]        @relation("CustomerProjects")
  assignedProjects Project[]        @relation("ProjectStaff")
  progressUpdates  ProgressUpdate[]
  notifications    Notification[]
  assignedLeads    Lead[]           @relation("AssignedLeads")
  markedPayments   PaymentMilestone[] @relation("MarkedPayments")
  recordedTransactions PaymentTransaction[] @relation("RecordedTransactions")
  uploadedMedia    Media[]
  auditLogs        AuditLog[]
  
  accounts      Account[]
  sessions      Session[]
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Account {
  id                 String  @id @default(cuid())
  userId             String
  type               String
  provider           String
  providerAccountId  String
  refresh_token      String?  @db.Text
  access_token       String?  @db.Text
  expires_at         Int?
  token_type         String?
  scope              String?
  id_token           String?  @db.Text
  session_state      String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ============================================
// Project
// ============================================

model Project {
  id                   String   @id @default(cuid())
  name                 String
  siteAddress          String
  city                 String
  plotSize             String
  builtUpArea          String
  startDate            DateTime?
  expectedCompletion   DateTime?
  currentStage         String    @default("planning")  // planning|foundation|columns|walls|slab|plumbing|electrical|finishing|handover
  status               String    @default("not_started") // not_started|in_progress|on_hold|completed|cancelled
  completionPercentage Int       @default(0)
  totalValue           Float     @default(0)
  amountPaid           Float     @default(0)
  planName             String?
  clientName           String?
  mobileNumber         String?
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  // Relations
  customerId String
  customer   User   @relation("CustomerProjects", fields: [customerId], references: [id])
  staff      User[] @relation("ProjectStaff")

  milestones          ProjectMilestone[]
  progressUpdates     ProgressUpdate[]
  documents           Document[]
  paymentTransactions PaymentTransaction[]
  payments            PaymentMilestone[]
  media               Media[]
}

// ============================================
// Project Milestone (one per construction stage)
// ============================================

model ProjectMilestone {
  id            String   @id @default(cuid())
  stage         String   // planning|foundation|columns|walls|slab|plumbing|electrical|finishing|handover
  title         String
  status        String   @default("upcoming") // completed|in_progress|upcoming
  startDate     DateTime?
  completedDate DateTime?
  description   String
  photoCount    Int      @default(0)
  notes         String?
  createdAt     DateTime @default(now())

  projectId String
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
}

// ============================================
// Progress Update
// ============================================

model ProgressUpdate {
  id                   String   @id @default(cuid())
  title                String
  description          String
  stage                String
  completionPercentage Int      @default(0)
  date                 String
  time                 String
  createdAt            DateTime @default(now())

  projectId  String
  project    Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  uploadedById String
  uploadedBy   User    @relation(fields: [uploadedById], references: [id])
  media        Media[]
}

// ============================================
// Media
// ============================================

model Media {
  id               String   @id @default(cuid())
  url              String
  fileType         String
  size             Int?     // bytes
  createdAt        DateTime @default(now())

  projectId        String?
  project          Project? @relation(fields: [projectId], references: [id], onDelete: Cascade)

  progressUpdateId String?
  progressUpdate   ProgressUpdate? @relation(fields: [progressUpdateId], references: [id], onDelete: SetNull)

  uploadedById     String
  uploadedBy       User     @relation(fields: [uploadedById], references: [id])
}

// ============================================
// Document
// ============================================

model Document {
  id         String   @id @default(cuid())
  name       String
  category   String   // agreement|plan|receipt|certificate|government|other
  fileType   String   // pdf|doc|img|dwg|xls
  fileSize   String
  uploadDate String
  uploadedBy String
  url        String
  isVisible  Boolean  @default(true)
  createdAt  DateTime @default(now())

  projectId String
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
}

// ============================================
// Payment Transactions
// ============================================

model PaymentTransaction {
  id            String   @id @default(cuid())
  amount        Float
  method        String   // upi|card|bank_transfer|cash|check
  transactionId String?
  idempotencyKey String? @unique
  notes         String?
  date          DateTime @default(now())

  projectId     String
  project       Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  recordedById  String?
  recordedBy    User?    @relation("RecordedTransactions", fields: [recordedById], references: [id])
}

// ============================================
// Payment Milestone
// ============================================

model PaymentMilestone {
  id          String   @id @default(cuid())
  name        String
  amount      Float
  paidAmount  Float    @default(0)
  dueDate     String
  paidDate    String?
  status      String   @default("pending") // paid|partial|pending|overdue
  receiptUrl  String?
  description String
  createdAt   DateTime @default(now())

  projectId String
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  markedPaidById String?
  markedPaidBy   User?   @relation("MarkedPayments", fields: [markedPaidById], references: [id])
}

// ============================================
// Lead / Enquiry
// ============================================

model Lead {
  id               String   @id @default(cuid())
  name             String
  email            String
  phone            String
  city             String
  plotSize         String?
  builtUpArea      String?
  budgetRange      String?
  homeType         String?  // independent_house|duplex|villa|row_house|farmhouse|commercial
  servicesNeeded   String   @default("[]") // JSON array
  timeline         String?
  preferredContact String   @default("phone") // phone|email|whatsapp
  notes            String?
  status           String   @default("new") // new|contacted|qualified|converted|rejected
  createdAt        DateTime @default(now())
  lastContactedAt  DateTime?

  assignedToId String?
  assignedTo   User?   @relation("AssignedLeads", fields: [assignedToId], references: [id])
}

// ============================================
// Notification
// ============================================

model Notification {
  id        String   @id @default(cuid())
  title     String
  message   String
  type      String   @default("info") // info|success|warning|error
  read      Boolean  @default(false)
  link      String?
  createdAt DateTime @default(now())

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ============================================
// Audit Log
// ============================================

model AuditLog {
  id         String   @id @default(cuid())
  action     String
  entityType String
  entityId   String
  userId     String
  details    String?  @db.Text // JSON string
  createdAt  DateTime @default(now())

  user       User     @relation(fields: [userId], references: [id])
}
